# ============================================================
# BGE Embedding 迁移配置示例
# 复制为 .env 后根据实际情况填写
# ============================================================

# ---------- Embedding Provider 选择 ----------
# 可选：local / modelscope / openai / minimax / qwen / zhipu / ollama / custom
# 默认 local（BGE 本地）
EMBEDDING_PROVIDER=local

# ---------- 本地 BGE 配置 ----------
# 模型目录（相对 backend/）
MODEL_DIR=./models
# HuggingFace 模型名称
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
# 强制使用真实模型（1=启用 BGE，0=降级到 hash）
USE_REAL_EMBEDDING=1

# ---------- ModelScope（魔塔社区）配置 ----------
# 线上部署推荐
MODELSCOPE_API_KEY=your_modelscope_api_key_here
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_MODEL_ID=BAAI/bge-small-zh-v1.5

# ---------- MiniMax 兜底配置 ----------
# 当本地 BGE 不可用时切换
OPENAI_API_KEY=your_minimax_api_key_here
MiniMax_GROUP_ID=your_group_id_here

# ---------- OpenAI 备选 ----------
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------- Qwen / Zhipu 备选 ----------
QWEN_API_KEY=your_qwen_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here
